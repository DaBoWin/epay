# Copy this file to .env before deployment.
# Do not commit your real .env file.

# MySQL root password used by the mysql container
EPAY_MYSQL_ROOT_PASSWORD=change_this_root_password

# Application database credentials
EPAY_DB_USER=epay_prod
EPAY_DB_PASSWORD=change_this_database_password
EPAY_DB_NAME=epay
EPAY_DB_PREFIX=pay
